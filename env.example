# Dr_Mirror — Production Environment Variables Template
# Copy this to .env or set these in your hosting provider (Vercel / MonsterASP.NET)

# --- Database ---
ConnectionStrings__Default="Server=localhost;Database=DrMirror;Trusted_Connection=True;TrustServerCertificate=True"

# --- Authentication ---
Jwt__Issuer="drmirror.com"
Jwt__Audience="drmirror.com"
Jwt__Secret="YOUR_64_CHAR_RANDOM_SECRET"

# --- Admin Seeding ---
Admin__SeedEmail="admin@drmirror.com"
Admin__SeedPassword="YOUR_STRONG_PASSWORD"

# --- Storage (Local or Cloudinary) ---
FileStorage__Provider="cloudinary"
FileStorage__CloudinaryCloudName="YOUR_CLOUD_NAME"
FileStorage__CloudinaryApiKey="YOUR_API_KEY"
FileStorage__CloudinaryApiSecret="YOUR_API_SECRET"

# --- Email (LogOnly or MailKit) ---
Email__Provider="mailkit"
Email__FromAddress="YOUR_EMAIL@gmail.com"
Email__FromName="Dr. Mirror"
Email__SmtpHost="smtp.gmail.com"
Email__SmtpPort=587
Email__SmtpUseStartTls=true
Email__SmtpUsername="YOUR_EMAIL@gmail.com"
Email__SmtpPassword="YOUR_APP_PASSWORD"
