# =============================================================================
# Dr Mirror — Monorepo .gitignore
# Backend: .NET 10 / ASP.NET Core
# Frontend: React + TypeScript + Vite
# WhatsApp Service: Node.js (Baileys)
# =============================================================================


# =============================================================================
# SECRETS & ENVIRONMENT
# =============================================================================
.env
.env.*
!.env.example
!.env.*.example

# ASP.NET Core appsettings — keep only the example template
backend/**/appsettings.json
backend/**/appsettings.*.json
!backend/**/appsettings.Example.json

# User secrets (dotnet user-secrets)
backend/**/*.csproj.user
backend/**/secrets.json


# =============================================================================
# .NET / C# BUILD OUTPUT
# =============================================================================
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# NuGet
*.nupkg
*.snupkg
.nuget/
nuget.config.local

# Publish output
[Pp]ublish/
[Pp]ublish[Oo]utput/

# Test results
[Tt]est[Rr]esult*/
TestResults/
*.trx
*.coverage
*.coveragexml
coverage*.json
coverage*.xml
coverage*.info

# Rider / MSBuild
.msbuildworkspacelogs/
msbuild.log
msbuild.err
msbuild.wrn

# Entity Framework migrations (never auto-generate) — track only explicitly added
# (all migrations are tracked; exclude none unless you want to override)


# =============================================================================
# NODE.JS (frontend & whatsapp-service)
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz


# =============================================================================
# FRONTEND — Vite / React / TypeScript
# =============================================================================
frontend/dist/
frontend/dist-ssr/
frontend/build/
frontend/coverage/
frontend/*.local

# ESLint artifact outputs
frontend/eslint-out.json
frontend/eslint-report.*

# Type-check cache
frontend/*.tsbuildinfo


# =============================================================================
# WHATSAPP SERVICE — Baileys session data
# =============================================================================
# Session contains auth keys — never commit
whatsapp-service/session/
whatsapp-service/sessions/
whatsapp-service/baileys_store*.json
whatsapp-service/baileys_auth_info/
whatsapp-service/*.db
whatsapp-service/*.db-shm
whatsapp-service/*.db-wal


# =============================================================================
# LOGS
# =============================================================================
*.log
*.log.*
logs/
log/


# =============================================================================
# DATABASES & STORAGE
# =============================================================================
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
*.mdf
*.ldf


# =============================================================================
# OS FILES
# =============================================================================

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~


# =============================================================================
# IDEs & EDITORS
# =============================================================================

# Visual Studio
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.rsuser
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]uild[Ll]og.*
*.VisualState.xml
*.pidb
*.svclog

# JetBrains Rider / IntelliJ
.idea/
*.iml
*.iws
out/
.idea_modules/

# VS Code — keep shared extensions/settings if desired; ignore personal overrides
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc


# =============================================================================
# DOCKER & DEPLOYMENT
# =============================================================================
.docker/
docker-compose.override.yml
docker-compose.local.yml

# Render / cloud secrets
render.local.yaml


# =============================================================================
# SCRATCH & TEMPORARY
# =============================================================================
scratch/
tmp/
temp/
*.tmp
*.bak
*.orig
*.rej
