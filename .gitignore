# ============================================================================
# Dr_Mirror — repo-root .gitignore
# ============================================================================

# === Node / Vite (frontend) ===
node_modules/
dist/
dist-ssr/
.vite/
*.local

# === .NET (backend) ===
bin/
obj/
out/
*.user
*.suo
*.userprefs
*.pidb
*.swp
*.swo
.vs/

# === Logs ===
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# === Editors & OS ===
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.sublime-workspace

# === Secrets / env ===
.env
.env.local
.env.*.local
*.pfx
*.p12
appsettings.*.Local.json
secrets.json

# === EF Core migrations artifacts that should not be committed ===
# (Migrations themselves ARE committed; only build artifacts excluded above)

# === Cloudinary / upload temp ===
tmp/
temp/
