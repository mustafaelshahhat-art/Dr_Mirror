PORT=3005
NODE_ENV=production
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/whatsapp_sessions?retryWrites=true&w=majority
INTERNAL_API_KEY=replace-with-long-random-backend-key-at-least-32-chars
# PAIRING_ADMIN_TOKEN is optional — when omitted, INTERNAL_API_KEY is accepted for pairing
PAIRING_ADMIN_TOKEN=replace-with-long-random-admin-pairing-token
ENABLE_PAIRING_UI=false
SEND_TIMEOUT_MS=15000
DAILY_PHONE_LIMIT=10
GLOBAL_SEND_LIMIT_PER_MINUTE=60
