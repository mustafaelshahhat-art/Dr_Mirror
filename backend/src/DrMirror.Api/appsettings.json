{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http": "Warning"
      }
    }
  },
  "Jwt": {
    "Issuer": "drmirror.local",
    "Audience": "drmirror.local",
    "AccessTokenLifetimeMinutes": 15,
    "RefreshTokenLifetimeDays": 14,
    "RefreshCookieName": "drmirror_refresh",
    "RefreshCookiePath": "/api/auth"
  },
  "Admin": {
    "SeedEmail": "admin@drmirror.local"
  },
  "Auth": {
    "UseCrossSiteCookies": false
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:4173"
    ]
  },
  "AllowedHosts": "*"
}
