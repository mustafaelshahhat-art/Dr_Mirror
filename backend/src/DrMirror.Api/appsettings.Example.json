{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http": "Warning"
      }
    }
  },
  "Jwt": {
    "Issuer": "drmirror.com",
    "Audience": "drmirror.com",
    "AccessTokenLifetimeMinutes": 15,
    "RefreshTokenLifetimeDays": 14,
    "RefreshCookieName": "drmirror_refresh",
    "RefreshCookiePath": "/api/auth",
    "Secret": "YOUR_64_CHAR_JWT_SECRET"
  },
  "Admin": {
    "SeedEmail": "admin@drmirror.com",
    "SeedPassword": "YOUR_STRONG_PASSWORD"
  },
  "FileStorage": {
    "Provider": "cloudinary",
    "CloudinaryCloudName": "YOUR_CLOUD_NAME",
    "CloudinaryApiKey": "YOUR_API_KEY",
    "CloudinaryApiSecret": "YOUR_API_SECRET"
  },
  "Email": {
    "Provider": "mailkit",
    "FromAddress": "no-reply@drmirror.com",
    "FromName": "Dr. Mirror",
    "ReplyToAddress": "support@drmirror.com",
    "FrontendBaseUrl": "https://your-frontend.vercel.app",
    "MessageIdDomain": "drmirror.com",
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "SmtpUseStartTls": true,
    "SmtpUsername": "YOUR_EMAIL@gmail.com",
    "SmtpPassword": "YOUR_APP_PASSWORD"
  },
  "WhatsApp": {
    "Enabled": false,
    "ServiceUrl": "https://YOUR-RENDER-SERVICE.onrender.com",
    "InternalApiKey": "YOUR_INTERNAL_API_KEY_AT_LEAST_32_CHARS",
    "TimeoutSeconds": 30,
    "MaxAttempts": 5,
    "DailyLimitPerPhone": 50,
    "MaxBackoff": "00:30:00",
    "RetentionDays": 90,
    "EnableRetentionPurge": true
  },
  "Cors": {
    "AllowedOrigins": [ "https://your-frontend.vercel.app" ]
  },
  "Security": {
    "Headers": {
      "HstsMaxAge": "31536000",
      "HstsIncludeSubDomains": true,
      "HstsPreload": false,
      "ContentTypeOptions": "nosniff",
      "ReferrerPolicy": "strict-origin-when-cross-origin",
      "FrameOptions": "DENY",
      "CrossOriginResourcePolicy": "same-site",
      "EmitInDevelopment": true,
      "EmitHstsOnlyOverHttps": true
    }
  },
  "Auth": {
    "UseCrossSiteCookies": false
  },
  "HealthChecks": {
    "OutboxStuckThreshold": 100
  },
  "Retention": {
    "EnableProofPurge": true,
    "ProofPurgeIntervalHours": 24,
    "OutboxRetentionDays": 90
  },
  "Support": {
    "ContactEmail": "support@drmirror.com"
  },
  "RateLimit": {
    "PermitLimitMultiplier": 1
  },
  "ConnectionStrings": {
    "Default": "Server=YOUR_SERVER.mssql.somee.com;Database=YOUR_DB;User Id=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=True;"
  }
}
