# =============================================================================
# Dr Mirror Backend — Environment Variables Reference
# =============================================================================
# All real production values MUST be set via MonsterASP Custom Environment
# Variables Settings (control panel → Application Settings).
#
# This file is a reference only. Copy to .env for local development.
# NEVER commit real secrets to version control.
#
# ASP.NET Core maps __ to : for hierarchical keys (e.g. ConnectionStrings__Default
# maps to ConnectionStrings:Default in IConfiguration).
# =============================================================================

# ── ASP.NET Core ────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production

# ── Database (SQL Server) ───────────────────────────────────────────────────
ConnectionStrings__Default=Server=YOUR_SERVER.mssql.somee.com;Database=YOUR_DB;User Id=YOUR_USER;Password=YOUR_PASSWORD;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=True;

# ── JWT ─────────────────────────────────────────────────────────────────────
Jwt__Secret=YOUR_64_CHAR_JWT_SECRET
Jwt__Issuer=drmirror.com
Jwt__Audience=drmirror.com
# Optional — defaults shown:
# Jwt__AccessTokenLifetimeMinutes=15
# Jwt__RefreshTokenLifetimeDays=14

# ── Admin Seed Account ──────────────────────────────────────────────────────
Admin__SeedEmail=admin@drmirror.com
Admin__SeedPassword=YOUR_STRONG_ADMIN_PASSWORD_MIN_12_CHARS

# ── CORS ────────────────────────────────────────────────────────────────────
Cors__AllowedOrigins__0=https://your-frontend.vercel.app
# Add more origins as needed: Cors__AllowedOrigins__1=https://custom-domain.com

# ── File Storage ────────────────────────────────────────────────────────────
# Options: cloudinary (recommended) | local
FileStorage__Provider=cloudinary
# Required when Provider=cloudinary:
FileStorage__CloudinaryCloudName=YOUR_CLOUD_NAME
FileStorage__CloudinaryApiKey=YOUR_API_KEY
FileStorage__CloudinaryApiSecret=YOUR_API_SECRET

# ── Email / SMTP (MailKit) ─────────────────────────────────────────────────
# Options: mailkit | logonly
Email__Provider=mailkit
Email__FromAddress=no-reply@drmirror.com
Email__FromName=Dr. Mirror
Email__FrontendBaseUrl=https://your-frontend.vercel.app
# Required when Provider=mailkit:
Email__SmtpHost=smtp.gmail.com
Email__SmtpPort=587
Email__SmtpUseStartTls=true
Email__SmtpUsername=YOUR_EMAIL@gmail.com
Email__SmtpPassword=YOUR_APP_PASSWORD
# Optional:
# Email__ReplyToAddress=support@drmirror.com
# Email__MessageIdDomain=drmirror.com

# ── WhatsApp Integration ────────────────────────────────────────────────────
WhatsApp__Enabled=true
WhatsApp__ServiceUrl=https://your-whatsapp.onrender.com
WhatsApp__InternalApiKey=YOUR_INTERNAL_API_KEY_32_CHARS_MIN
# Optional — defaults shown:
# WhatsApp__TimeoutSeconds=30
# WhatsApp__SendTimeoutSeconds=15
# WhatsApp__PollIntervalMs=1000
# WhatsApp__MaxSendConcurrency=3
# WhatsApp__MaxAttempts=5
# WhatsApp__DailyLimitPerPhone=50
# WhatsApp__MaxBackoff=00:30:00
# WhatsApp__RetentionDays=90
# WhatsApp__EnableRetentionPurge=true

# ── Auth ────────────────────────────────────────────────────────────────────
# REQUIRED in production when the frontend is on a different origin than the API
# (e.g. Vercel → MonsterASP). Without this the refresh cookie is set with
# SameSite=Lax and browsers silently strip it from cross-origin POST requests,
# breaking session persistence on every page reload.
Auth__UseCrossSiteCookies=true

# ── Rate Limiting ───────────────────────────────────────────────────────────
# RateLimit__PermitLimitMultiplier=1

# ── Retention ───────────────────────────────────────────────────────────────
# Retention__EnableProofPurge=true
# Retention__ProofPurgeIntervalHours=24
# Retention__OutboxRetentionDays=90
# Retention__EnableOutboxPurge=true

# ── Health Checks ───────────────────────────────────────────────────────────
# HealthChecks__OutboxStuckThreshold=100

# ── Support ─────────────────────────────────────────────────────────────────
Support__ContactEmail=support@drmirror.com
