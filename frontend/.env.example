# --- API Configuration ---
# In development, leave blank to use the Vite proxy (/api)
# In production, set to your deployed backend origin (e.g., https://api.drmirror.shop)
# /api is appended automatically by the API client
VITE_API_BASE_URL=

# --- Dev Proxy (local only — ignored in production builds) ---
# Target backend for the Vite dev server proxy
VITE_API_PROXY_TARGET=http://localhost:5223

# --- Sentry Error Tracking (optional) ---
# Leave blank to disable Sentry entirely
VITE_SENTRY_DSN=
VITE_APP_RELEASE=

# Sentry source-map upload (set in Vercel build env, not in .env)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
